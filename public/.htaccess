# SPA fallback for Apache (REG.RU и любой shared hosting на Apache).
# Сначала пытаемся отдать статический файл/каталог (например, /bankruptcy/index.html),
# и только если ничего не нашли — отдаём корневой index.html (SPA-фолбэк).

DirectoryIndex index.html
Options +FollowSymLinks -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1) Если путь — каталог без слеша (например, /bankruptcy), добавляем слеш,
  #    чтобы mod_dir отдал его DirectoryIndex (bankruptcy/index.html).
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^(.+[^/])$ /$1/ [R=301,L]

  # 2) Реально существующие файлы и каталоги отдаём как есть.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3) Всё остальное — корневой index.html (SPA-фолбэк для прочих маршрутов).
  RewriteRule . /index.html [L]
</IfModule>

# Кэшируем ассеты на год (хэш в имени файла обеспечивает инвалидацию)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css                 "access plus 1 year"
  ExpiresByType application/javascript   "access plus 1 year"
  ExpiresByType image/png                "access plus 1 year"
  ExpiresByType image/jpeg               "access plus 1 year"
  ExpiresByType image/webp               "access plus 1 year"
  ExpiresByType image/svg+xml            "access plus 1 year"
  ExpiresByType font/woff2               "access plus 1 year"
  ExpiresByType text/html                "access plus 0 seconds"
</IfModule>

# Сжатие
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>